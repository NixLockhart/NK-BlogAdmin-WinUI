<Page
    x:Class="Blog_Manager.Views.MessagesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <!-- Messages List (Animated) -->
        <ScrollViewer>
            <ScrollViewer.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </ScrollViewer.Transitions>
            <ListView ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Message">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="16"
                               Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Author Info -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Nickname}"
                                                  FontWeight="SemiBold"
                                                  FontSize="14"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="|"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind DisplayEmail}"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  FontSize="12"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="|"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  Visibility="{x:Bind BlogUrlVisibility}"
                                                  VerticalAlignment="Center"/>
                                        <HyperlinkButton Content="{x:Bind DisplayBlogUrl}"
                                                        NavigateUri="{x:Bind BlogUri}"
                                                        FontSize="12"
                                                        Padding="0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{x:Bind BlogUrlVisibility}"/>
                                        <TextBlock Text="|"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE81D;"
                                                     FontSize="12"
                                                     Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind IpLocation, Mode=OneWay}"
                                                      Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                      FontSize="12"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="|"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind DisplayCreatedAt}"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  FontSize="12"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Status badges -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <!-- 已删除标签 -->
                                        <Border Background="{ThemeResource SystemFillColorCriticalBrush}"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsDeletedVisibility}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="White"/>
                                                <TextBlock Text="已删除"
                                                          Foreground="White"
                                                          FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- 友链标签 -->
                                        <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsFriendVisibility}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE734;" FontSize="12" Foreground="White"/>
                                                <TextBlock Text="友情链接"
                                                          Foreground="White"
                                                          FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Content -->
                                <TextBlock Grid.Row="1"
                                          Text="{x:Bind Content}"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,12"/>

                                <!-- Actions -->
                                <Grid Grid.Row="2">
                                    <!-- 正常状态显示操作按钮 -->
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                               Visibility="{x:Bind NotDeletedVisibility}">
                                        <Button Tag="{x:Bind Id}"
                                               Click="ToggleFriendButton_Click"
                                               Visibility="{x:Bind FriendLinkButtonVisibility}">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE734;"/>
                                                <TextBlock Text="{x:Bind FriendLinkButtonText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Tag="{x:Bind Id}"
                                               Click="DeleteButton_Click">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonForeground" Color="#D32F2F"/>
                                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D32F2F"/>
                                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#B71C1C"/>
                                            </Button.Resources>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <SymbolIcon Symbol="Delete"/>
                                                <TextBlock Text="删除" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <!-- 已删除状态显示提示文字 -->
                                    <TextBlock Text="该留言已被删除"
                                              Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontStyle="Italic"
                                              FontSize="12"
                                              Visibility="{x:Bind IsDeletedVisibility}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
