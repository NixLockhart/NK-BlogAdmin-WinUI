<Page
    x:Class="Blog_Manager.Views.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <!-- Content Area (Animated) -->
        <Grid>
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </Grid.Transitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Error Display -->
            <InfoBar Grid.Row="0"
                     Severity="Error"
                     Title="加载失败"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Margin="0,0,0,16"/>

            <!-- Config List -->
            <ScrollViewer Grid.Row="1">
            <ListView ItemsSource="{x:Bind ViewModel.Configs, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SiteConfig">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="16"
                               Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Config Key -->
                                <TextBlock Grid.Row="0"
                                          Text="{x:Bind ConfigKey}"
                                          FontWeight="SemiBold"
                                          FontSize="16"
                                          Margin="0,0,0,8"/>

                                <!-- Description -->
                                <TextBlock Grid.Row="1"
                                          Text="{x:Bind Description}"
                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                          FontSize="12"
                                          Margin="0,0,0,12"/>

                                <!-- Config Value Input -->
                                <TextBox Grid.Row="2"
                                        x:Name="ValueTextBox"
                                        Header="配置值"
                                        Text="{x:Bind ConfigValue, Mode=OneWay}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        MinHeight="60"
                                        Margin="0,0,0,12"/>

                                <!-- Actions -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                    <Button Tag="{x:Bind ConfigKey}"
                                           Click="UpdateButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Save"/>
                                            <TextBlock Text="保存" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Tag="{x:Bind ConfigKey}"
                                           Click="DeleteButton_Click">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonForeground" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#B71C1C"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Delete"/>
                                            <TextBlock Text="删除" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
              Opacity="0.8">
            <ProgressRing IsActive="True"
                         Width="60"
                         Height="60"/>
        </Grid>
    </Grid>
</Page>
