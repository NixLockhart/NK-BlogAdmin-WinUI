<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Blog_Manager.Views.ArticlesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    xmlns:converters="using:Blog_Manager.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToUriConverter x:Key="StringToUriConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <!-- Content Area (Animated) -->
        <Grid>
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </Grid.Transitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- Filter Toolbar -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Filter by Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,16,0">
                    <TextBlock Text="按状态筛选:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="StatusFilterComboBox"
                             PlaceholderText="全部状态"
                             MinWidth="120"
                             SelectionChanged="StatusFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="全部" Tag=""/>
                        <ComboBoxItem Content="已发布" Tag="1"/>
                        <ComboBoxItem Content="草稿" Tag="2"/>
                        <ComboBoxItem Content="已删除" Tag="0"/>
                    </ComboBox>
                </StackPanel>

                <!-- Filter by Category -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="按分类筛选:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CategoryFilterComboBox"
                             PlaceholderText="全部分类"
                             MinWidth="150"
                             SelectionChanged="CategoryFilterComboBox_SelectionChanged"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading/Error States -->
        <StackPanel x:Name="LoadingPanel"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <ProgressRing IsActive="True" Width="50" Height="50"/>
            <TextBlock Text="加载中..." TextAlignment="Center"/>
        </StackPanel>

        <InfoBar x:Name="ErrorInfoBar"
                 Grid.Row="1"
                 Visibility="Collapsed"
                 Severity="Error"
                 IsClosable="True"
                 Title="加载失败"/>

        <!-- Articles DataGrid -->
        <ScrollViewer x:Name="ContentPanel"
                     Grid.Row="2"
                     VerticalScrollBarVisibility="Auto">
            <ListView x:Name="ArticlesListView"
                     ItemsSource="{x:Bind ViewModel.Articles, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Article">
                        <Grid Padding="12"
                             BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                             BorderThickness="1"
                             CornerRadius="8"
                             Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                             Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cover Image -->
                            <Border Grid.Column="0"
                                   Width="100"
                                   Height="70"
                                   CornerRadius="4"
                                   Background="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                                   Margin="0,0,16,0">
                                <!-- 使用 Binding 而不是 x:Bind，因为需要 Converter -->
                                <Image Stretch="UniformToFill"
                                      Source="{Binding CoverImageUrl, Mode=OneWay, Converter={StaticResource StringToUriConverter}}"/>
                            </Border>

                            <!-- Article Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                <!-- Title with Top Badge -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{ThemeResource SystemFillColorCriticalBrush}"
                                           CornerRadius="4"
                                           Padding="4,2"
                                           Visibility="{x:Bind IsTopVisibility, Mode=OneWay}">
                                        <TextBlock Text="置顶"
                                                 Foreground="White"
                                                 FontSize="11"
                                                 FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="#E8A317"
                                           CornerRadius="4"
                                           Padding="4,2"
                                           Visibility="{x:Bind HasDraftVisibility, Mode=OneWay}">
                                        <TextBlock Text="有未保存的修改"
                                                 Foreground="White"
                                                 FontSize="11"
                                                 FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                             Style="{StaticResource BodyStrongTextBlockStyle}"
                                             TextTrimming="CharacterEllipsis"
                                             MaxLines="1"/>
                                </StackPanel>

                                <!-- Summary -->
                                <TextBlock Text="{x:Bind SafeSummary, Mode=OneWay}"
                                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                         TextTrimming="CharacterEllipsis"
                                         MaxLines="2"
                                         FontSize="12"/>

                                <!-- Metadata -->
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                             FontSize="11">
                                        <Run Text="分类:"/>
                                        <Run Text="{x:Bind SafeCategoryName, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                             Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                             FontSize="11"/>
                                    <TextBlock Text="{x:Bind CreatedAtText, Mode=OneWay}"
                                             Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                             FontSize="11"/>
                                    <!-- 永久删除倒计时 -->
                                    <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            Visibility="{x:Bind DeletionCountdownVisibility, Mode=OneWay}">
                                        <TextBlock Text="{x:Bind DeletionCountdownText, Mode=OneWay}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Border>
                                </StackPanel>

                                <!-- Stats -->
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8F4;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind ViewsText, Mode=OneWay}"
                                                 FontSize="11"
                                                 Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8E1;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind LikesText, Mode=OneWay}"
                                                 FontSize="11"
                                                 Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8F2;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                        <TextBlock Text="{x:Bind CommentCountText, Mode=OneWay}"
                                                 FontSize="11"
                                                 Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Grid.Column="2"
                                       Orientation="Horizontal"
                                       VerticalAlignment="Center"
                                       Spacing="8">
                                <!-- 编辑按钮（非已删除文章） -->
                                <Button Style="{StaticResource AccentButtonStyle}"
                                       Content="编辑"
                                       Click="EditArticleButton_Click"
                                       Tag="{x:Bind Id, Mode=OneWay}"
                                       Visibility="{x:Bind IsNotDeletedVisibility, Mode=OneWay}"/>
                                <!-- 查看按钮（已删除文章） -->
                                <Button Content="查看"
                                       Click="ViewArticleButton_Click"
                                       Tag="{x:Bind Id, Mode=OneWay}"
                                       Visibility="{x:Bind IsDeletedVisibility, Mode=OneWay}"/>
                                <!-- 置顶按钮（非已删除文章） -->
                                <Button Content="置顶"
                                       Click="ToggleTopButton_Click"
                                       Tag="{x:Bind Id, Mode=OneWay}"
                                       Visibility="{x:Bind IsNotDeletedVisibility, Mode=OneWay}"/>
                                <!-- 恢复按钮（已删除文章） -->
                                <Button Content="恢复"
                                       Click="RestoreArticleButton_Click"
                                       Tag="{x:Bind Id, Mode=OneWay}"
                                       Visibility="{x:Bind IsDeletedVisibility, Mode=OneWay}"/>
                                <!-- 删除按钮（非已删除文章） -->
                                <Button Content="删除"
                                       Click="DeleteArticleButton_Click"
                                       Tag="{x:Bind Id, Mode=OneWay}"
                                       Visibility="{x:Bind IsNotDeletedVisibility, Mode=OneWay}">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonForeground" Color="Red"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="DarkRed"/>
                                    </Button.Resources>
                                </Button>
                                <!-- 永久删除按钮（已删除文章） -->
                                <Button Content="永久删除"
                                       Click="PermanentDeleteArticleButton_Click"
                                       Tag="{x:Bind Id, Mode=OneWay}"
                                       Visibility="{x:Bind IsDeletedVisibility, Mode=OneWay}">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonForeground" Color="Red"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="Red"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="DarkRed"/>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
        </Grid>
    </Grid>
</Page>
