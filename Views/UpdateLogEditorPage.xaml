<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Blog_Manager.Views.UpdateLogEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- Loading/Error States -->
        <StackPanel x:Name="LoadingPanel"
                   Visibility="Collapsed"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Spacing="12">
            <ProgressRing IsActive="True" Width="50" Height="50"/>
            <TextBlock Text="加载中..." TextAlignment="Center"/>
        </StackPanel>

        <InfoBar x:Name="ErrorInfoBar"
                Visibility="Collapsed"
                Severity="Error"
                IsClosable="True"
                Title="操作失败"
                Margin="24"/>

        <!-- Main Content -->
        <Grid x:Name="ContentPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" Padding="24">
                <StackPanel Spacing="16">
                    <!-- Version Input -->
                    <TextBox x:Name="VersionTextBox"
                            Header="版本号 *"
                            PlaceholderText="例如: v1.0.0"
                            FontSize="20"
                            FontWeight="SemiBold"/>

                    <!-- Title Input -->
                    <TextBox x:Name="TitleTextBox"
                            Header="标题 (可选)"
                            PlaceholderText="更新标题"/>

                    <!-- Settings Row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Release Date -->
                        <CalendarDatePicker x:Name="ReleaseDatePicker"
                                           Grid.Column="0"
                                           Header="发布日期"
                                           PlaceholderText="选择发布日期"
                                           HorizontalAlignment="Left"
                                           MinWidth="200"/>

                        <!-- Major Update Toggle -->
                        <ToggleSwitch x:Name="IsMajorToggle"
                                     Grid.Column="1"
                                     Header="重大更新"
                                     OffContent="普通更新"
                                     OnContent="重大更新"
                                     VerticalAlignment="Bottom"/>
                    </Grid>

                    <!-- Content Editor -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="更新内容 *"
                                  Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        <TextBlock Text="支持 Markdown 格式"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  FontSize="12"/>
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               MinHeight="400">
                            <TextBox x:Name="ContentTextBox"
                                    PlaceholderText="输入更新内容...&#x0a;&#x0a;例如:&#x0a;- 新增功能 A&#x0a;- 修复问题 B&#x0a;- 优化性能 C"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    FontFamily="Consolas"
                                    FontSize="14"
                                    Padding="16"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </StackPanel>

                    <!-- Tips -->
                    <InfoBar IsOpen="True"
                            IsClosable="False"
                            Severity="Informational"
                            Title="提示"
                            Message="更新内容支持 Markdown 格式，可以使用 - 创建列表、** 加粗文字等"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
