<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Blog_Manager.Views.PublishConfigDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="发布配置"
    PrimaryButtonText="确认"
    CloseButtonText="取消"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="600">
        <StackPanel Spacing="16" Padding="4" Width="480">
            <!-- Category Selection -->
            <ComboBox x:Name="CategoryComboBox"
                     Header="文章分类 *"
                     PlaceholderText="选择分类"
                     HorizontalAlignment="Stretch"
                     MinWidth="400"/>

            <!-- Cover Image Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="封面图片" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="CoverImageTextBox"
                            Grid.Column="0"
                            PlaceholderText="图片URL或点击右侧按钮上传"
                            Margin="0,0,8,0"
                            LostFocus="CoverImageTextBox_LostFocus"/>

                    <Button x:Name="UploadCoverButton"
                           Grid.Column="1"
                           Click="UploadCoverButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon x:Name="UploadIcon" Symbol="Upload"/>
                            <TextBlock x:Name="UploadButtonText" Text="上传封面"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Upload Progress -->
                <ProgressBar x:Name="UploadProgressBar"
                            Visibility="Collapsed"
                            IsIndeterminate="True"
                            ShowError="False"/>

                <!-- Cover Preview -->
                <Border x:Name="CoverPreviewBorder"
                       Width="400"
                       Height="225"
                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       HorizontalAlignment="Left"
                       Visibility="Collapsed">
                    <Image x:Name="CoverPreviewImage"
                          Stretch="UniformToFill"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Summary -->
            <TextBox x:Name="SummaryTextBox"
                    Header="文章摘要"
                    PlaceholderText="文章摘要（选填，留空将自动提取）"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    Height="120"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <TextBlock Text="提示：点击确认后将保存文章"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
