<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Blog_Manager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Blog_Manager.Views"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Content Area (Animated) -->
        <Grid Grid.Row="0">
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </Grid.Transitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Error Message -->
            <InfoBar Grid.Row="0"
                     Severity="Error"
                     Title="加载失败"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Margin="0,0,0,16"/>

            <!-- Statistics Cards -->
            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="24">
                <!-- Quick Stats Grid -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Visits Card -->
                    <Border Grid.Row="0" Grid.Column="0"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="&#xE909;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalVisits, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="总访问量"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Today Visits Card -->
                    <Border Grid.Row="0" Grid.Column="1"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="&#xE8B7;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FF6B9BD1"/>
                            <TextBlock Text="{x:Bind ViewModel.TodayVisits, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="今日访问"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Article Count Card -->
                    <Border Grid.Row="0" Grid.Column="2"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="&#xE8A5;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FF9B59B6"/>
                            <TextBlock Text="{x:Bind ViewModel.ArticleCount, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="文章数"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Like Count Card -->
                    <Border Grid.Row="0" Grid.Column="3"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="&#xE19F;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FFE74C3C"/>
                            <TextBlock Text="{x:Bind ViewModel.LikeCount, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="点赞数"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Comment Count Card -->
                    <Border Grid.Row="1" Grid.Column="0"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="&#xE8BD;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FF3498DB"/>
                            <TextBlock Text="{x:Bind ViewModel.CommentCount, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="评论数"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Message Count Card -->
                    <Border Grid.Row="1" Grid.Column="1"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="&#xE8F2;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FF1ABC9C"/>
                            <TextBlock Text="{x:Bind ViewModel.MessageCount, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="留言数"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Runtime Card -->
                    <Border Grid.Row="1" Grid.Column="2"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20"
                           Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="&#xE916;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FFF39C12"/>
                            <TextBlock Text="{x:Bind ViewModel.Runtime, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="运行时长"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- System Version Card -->
                    <Border Grid.Row="1" Grid.Column="3"
                           Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                           BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                           BorderThickness="1"
                           CornerRadius="8"
                           Padding="20">
                        <StackPanel>
                            <TextBlock Text="&#xE895;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="24"
                                      Foreground="#FF95A5A6"/>
                            <TextBlock Text="{x:Bind ViewModel.SystemVersion, Mode=OneWay}"
                                      FontSize="28"
                                      FontWeight="SemiBold"
                                      Margin="0,12,0,0"/>
                            <TextBlock Text="系统版本"
                                      FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ComboBox x:Name="ChartSelector"
                                  Grid.Row="0"
                                  SelectedIndex="0"
                                  SelectionChanged="ChartSelector_SelectionChanged"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="近30天访问趋势"/>
                            <ComboBoxItem Content="文章浏览量 Top 10"/>
                        </ComboBox>

                        <!-- Visit Trend Chart -->
                        <lvc:CartesianChart x:Name="VisitTrendChart"
                                           Grid.Row="1"
                                           Series="{x:Bind ViewModel.VisitSeries, Mode=OneWay}"
                                           XAxes="{x:Bind ViewModel.VisitXAxes, Mode=OneWay}"
                                           YAxes="{x:Bind ViewModel.VisitYAxes, Mode=OneWay}"
                                           Height="300"
                                           ZoomMode="None"
                                           LegendPosition="Hidden"/>

                        <!-- Article Ranking Chart -->
                        <lvc:CartesianChart x:Name="ArticleRankingChart"
                                           Grid.Row="1"
                                           Series="{x:Bind ViewModel.RankingSeries, Mode=OneWay}"
                                           XAxes="{x:Bind ViewModel.RankingXAxes, Mode=OneWay}"
                                           YAxes="{x:Bind ViewModel.RankingYAxes, Mode=OneWay}"
                                           Height="300"
                                           Visibility="Collapsed"
                                           LegendPosition="Hidden"/>
                    </Grid>
                </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
