<Page
    x:Class="Blog_Manager.Views.ThemesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    xmlns:converters="using:Blog_Manager.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <!-- 主题网格 -->
        <ScrollViewer>
            <ScrollViewer.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </ScrollViewer.Transitions>
            <GridView ItemsSource="{x:Bind ViewModel.Themes, Mode=OneWay}"
                     SelectionMode="None"
                     Padding="8">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:Theme">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Width="280"
                               Height="340"
                               Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 封面预览 -->
                                <Border Grid.Row="0"
                                       CornerRadius="8,8,0,0"
                                       Background="{ThemeResource LayerFillColorDefaultBrush}">
                                    <Grid>
                                        <Image Source="{x:Bind CoverUrl}"
                                              Stretch="UniformToFill"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                                        <!-- 右上角更多按钮 -->
                                        <Button HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               Margin="8"
                                               Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
                                               Width="32"
                                               Height="32"
                                               Padding="0"
                                               CornerRadius="16"
                                               Tag="{x:Bind Id}"
                                               Click="MoreButton_Click"
                                               Visibility="{x:Bind IsDefault, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <SymbolIcon Symbol="More"/>
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="导出"
                                                                   Icon="Download"
                                                                   Tag="{x:Bind Id}"
                                                                   Click="ExportMenuItem_Click"/>
                                                    <MenuFlyoutSeparator/>
                                                    <MenuFlyoutItem Text="删除"
                                                                   Icon="Delete"
                                                                   Tag="{x:Bind Id}"
                                                                   Click="DeleteMenuItem_Click"/>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>

                                        <!-- 默认主题标签 -->
                                        <Border HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               Margin="8"
                                               Background="{ThemeResource SystemFillColorAttentionBrush}"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsDefault, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="默认主题"
                                                      FontSize="11"
                                                      Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 主题信息和操作 -->
                                <Grid Grid.Row="1" Padding="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 名称 -->
                                    <TextBlock Grid.Row="0"
                                              Text="{x:Bind Name}"
                                              FontSize="16"
                                              FontWeight="SemiBold"
                                              TextTrimming="CharacterEllipsis"
                                              Margin="0,0,0,8"/>

                                    <!-- 状态 -->
                                    <Border Grid.Row="1"
                                           VerticalAlignment="Top"
                                           Background="{ThemeResource SystemFillColorSuccessBrush}"
                                           CornerRadius="4"
                                           Padding="8,4"
                                           HorizontalAlignment="Left"
                                           Visibility="{x:Bind IsApplied, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="已应用"
                                                  FontSize="12"
                                                  Foreground="White"/>
                                    </Border>

                                    <!-- 操作按钮 -->
                                    <Grid Grid.Row="2">
                                        <StackPanel Orientation="Horizontal"
                                                   Spacing="8"
                                                   HorizontalAlignment="Center">
                                            <!-- 应用/取消应用按钮 -->
                                            <Button Tag="{x:Bind Id}"
                                                   Click="ApplyButton_Click"
                                                   Visibility="{x:Bind IsApplied, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                   Style="{StaticResource AccentButtonStyle}"
                                                   Height="32"
                                                   Width="150">
                                                <TextBlock Text="应用"/>
                                            </Button>
                                            <Button Tag="{x:Bind Id}"
                                                   Click="CancelApplyButton_Click"
                                                   Visibility="{x:Bind IsApplied, Converter={StaticResource BoolToVisibilityConverter}}"
                                                   Height="32"
                                                   Width="150">
                                                <TextBlock Text="取消应用"/>
                                            </Button>

                                            <!-- 编辑按钮 -->
                                            <Button Tag="{x:Bind Id}"
                                                   Click="EditButton_Click"
                                                   Visibility="{x:Bind IsDefault, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                   Height="32"
                                                   Width="80">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                                    <TextBlock Text="编辑"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>
