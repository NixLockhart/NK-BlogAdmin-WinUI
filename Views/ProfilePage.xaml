<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Blog_Manager.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Blog_Manager.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    SizeChanged="Page_SizeChanged">

    <Page.Resources>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer Padding="24">
            <ScrollViewer.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </ScrollViewer.Transitions>

            <StackPanel Spacing="24">

                <!-- Error Display -->
                <InfoBar x:Name="ErrorInfoBar"
                         Severity="Error"
                         Title="错误"
                         Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                         IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"/>

                <!-- Profile Header Card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <!-- 使用 StackPanel 实现垂直堆叠，窄屏时自然换行 -->
                    <StackPanel x:Name="ProfileHeaderPanel" Spacing="24">
                        <!-- 头像和基本信息行 -->
                        <StackPanel x:Name="AvatarInfoPanel" Orientation="Horizontal" Spacing="24">
                            <!-- Avatar Section -->
                            <StackPanel Spacing="12" VerticalAlignment="Top">
                                <Grid>
                                    <PersonPicture x:Name="AvatarPicture"
                                                  Width="80"
                                                  Height="80"
                                                  ProfilePicture="{x:Bind ViewModel.Avatar, Mode=OneWay, Converter={StaticResource StringToImageSourceConverter}}"
                                                  DisplayName="{x:Bind ViewModel.Nickname, Mode=OneWay}"/>

                                    <!-- Status Badge -->
                                    <Border x:Name="StatusBadge"
                                            Background="Green"
                                            CornerRadius="6"
                                            Padding="4,2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,-2,-2">
                                        <TextBlock Text="在线" FontSize="9" Foreground="White" FontWeight="Medium"/>
                                    </Border>
                                </Grid>

                                <Button Content="更换头像"
                                        HorizontalAlignment="Center"
                                        Click="ChangeAvatarButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        FontSize="12"
                                        Padding="12,6"/>
                            </StackPanel>

                            <!-- User Info Section -->
                            <StackPanel Spacing="8" VerticalAlignment="Center" MinWidth="200">
                                <TextBlock Text="{x:Bind ViewModel.Profile.Username, Mode=OneWay, FallbackValue='加载中...'}"
                                           FontSize="24"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{x:Bind ViewModel.Nickname, Mode=OneWay}"
                                           FontSize="14"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="{x:Bind ViewModel.Nickname, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                    <!-- Email Badge -->
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Visibility="{x:Bind ViewModel.Email, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE715;" FontSize="12"/>
                                            <TextBlock Text="{x:Bind ViewModel.Email, Mode=OneWay}" FontSize="12"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Status Badge -->
                                    <Border x:Name="AccountStatusBadge"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon x:Name="StatusIcon" Glyph="&#xE73E;" FontSize="12"/>
                                            <TextBlock x:Name="StatusText" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Stats Section - 独立一行 -->
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="6"
                                Padding="16,12">
                            <StackPanel Orientation="Horizontal" Spacing="32">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="最后登录"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="LastLoginText"
                                               FontSize="12"
                                               FontWeight="Medium"/>
                                </StackPanel>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="注册时间"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock x:Name="CreatedAtText"
                                               FontSize="12"
                                               FontWeight="Medium"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Forms Container - 响应式布局 -->
                <Grid x:Name="FormsContainer">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftColumn" Width="*"/>
                        <ColumnDefinition x:Name="SpacerColumn" Width="16"/>
                        <ColumnDefinition x:Name="RightColumn" Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left Column: Edit Profile -->
                    <Border x:Name="EditProfileCard"
                            Grid.Column="0"
                            Grid.Row="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                        <StackPanel Spacing="20">
                            <!-- Section Header -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE70F;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="编辑资料"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="修改您的个人信息"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="28,0,0,0"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                            <!-- Form Fields -->
                            <StackPanel Spacing="16">
                                <TextBox Header="昵称"
                                         PlaceholderText="设置一个显示名称"
                                         Text="{x:Bind ViewModel.Nickname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="50"/>

                                <TextBox Header="邮箱"
                                         PlaceholderText="your@email.com"
                                         Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="100"
                                         InputScope="EmailNameOrAddress"/>
                            </StackPanel>

                            <!-- Action Buttons -->
                            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                                <Button Click="ResetFormButton_Click" MinWidth="70">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                        <TextBlock Text="重置"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource AccentButtonStyle}"
                                        Click="SaveProfileButton_Click"
                                        IsEnabled="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                        MinWidth="90">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74E;" FontSize="12"/>
                                        <TextBlock Text="保存更改"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Right Column: Change Password -->
                    <Border x:Name="PasswordCard"
                            Grid.Column="2"
                            Grid.Row="0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                        <StackPanel Spacing="20">
                            <!-- Section Header -->
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                    <TextBlock Text="安全设置"
                                               FontSize="16"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="修改登录密码"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           Margin="28,0,0,0"/>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                            <!-- Password Fields -->
                            <StackPanel Spacing="16">
                                <PasswordBox x:Name="OldPasswordBox"
                                             Header="当前密码"
                                             PlaceholderText="输入当前密码"
                                             PasswordChanged="PasswordBox_PasswordChanged"
                                             MaxLength="50"/>

                                <PasswordBox x:Name="NewPasswordBox"
                                             Header="新密码"
                                             PlaceholderText="至少8位，包含字母和数字"
                                             PasswordChanged="PasswordBox_PasswordChanged"
                                             MaxLength="50"/>

                                <PasswordBox x:Name="ConfirmPasswordBox"
                                             Header="确认新密码"
                                             PlaceholderText="再次输入新密码"
                                             PasswordChanged="PasswordBox_PasswordChanged"
                                             MaxLength="50"/>
                            </StackPanel>

                            <!-- Action Button -->
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Click="ChangePasswordButton_Click"
                                    IsEnabled="{x:Bind ViewModel.IsSaving, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                    HorizontalAlignment="Right"
                                    MinWidth="100">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72E;" FontSize="12"/>
                                    <TextBlock Text="修改密码"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingPanel"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="Collapsed"
              Opacity="0.9">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="加载中..." Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Status InfoBar -->
        <InfoBar x:Name="StatusInfoBar"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,24"
                 Visibility="Collapsed"
                 IsClosable="True"/>
    </Grid>
</Page>
