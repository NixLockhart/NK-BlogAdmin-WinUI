<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Blog_Manager.Views.CreateConfigDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="新建配置"
    PrimaryButtonText="创建"
    CloseButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <ScrollViewer MaxHeight="500">
        <StackPanel Spacing="16" Padding="4">
            <!-- 配置键 -->
            <TextBox x:Name="ConfigKeyTextBox"
                     Header="配置键 *"
                     PlaceholderText="例如: custom_feature_enabled"
                     IsSpellCheckEnabled="False"/>

            <!-- 配置值 -->
            <TextBox x:Name="ConfigValueTextBox"
                     Header="配置值"
                     PlaceholderText="配置的值"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="80"/>

            <!-- 配置类型 -->
            <ComboBox x:Name="ConfigTypeComboBox"
                      Header="配置类型 *"
                      SelectedIndex="0"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem Content="string" />
                <ComboBoxItem Content="json" />
                <ComboBoxItem Content="boolean" />
                <ComboBoxItem Content="value" />
            </ComboBox>

            <!-- 配置描述 -->
            <TextBox x:Name="DescriptionTextBox"
                     Header="配置描述"
                     PlaceholderText="对该配置的描述"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"/>

            <!-- 是否公开 -->
            <CheckBox x:Name="IsPublicCheckBox"
                      Content="公开配置（前台可访问）"
                      IsChecked="False"/>

            <!-- 错误提示 -->
            <InfoBar x:Name="ErrorInfoBar"
                     Severity="Error"
                     IsOpen="False"
                     IsClosable="True"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
