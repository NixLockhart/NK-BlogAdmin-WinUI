<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Blog_Manager.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Blog_Manager.Views"
    xmlns:services="using:Blog_Manager.Services"
    xmlns:converters="using:Blog_Manager.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ObjectToVisibilityConverter x:Key="ObjectToVisibilityConverter"/>
        <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
        <converters:BoolToTestResultConverter x:Key="BoolToTestResultConverter"/>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Page.Resources>

    <Grid>
        <!-- Main Content -->
        <ScrollViewer Padding="24">
            <ScrollViewer.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </ScrollViewer.Transitions>

            <StackPanel Spacing="24">

                <!-- Appearance Settings -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE790;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="外观"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="自定义应用的主题风格"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       Margin="28,0,0,0"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <!-- Theme Selection -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="应用主题" FontWeight="Medium"/>
                                <TextBlock Text="选择浅色、深色或跟随系统设置"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                                <RadioButton x:Name="LightThemeRadio" Content="浅色" Tag="Light" GroupName="ThemeGroup" Checked="ThemeRadio_Checked"/>
                                <RadioButton x:Name="DarkThemeRadio" Content="深色" Tag="Dark" GroupName="ThemeGroup" Checked="ThemeRadio_Checked"/>
                                <RadioButton x:Name="DefaultThemeRadio" Content="跟随系统" Tag="Default" GroupName="ThemeGroup" IsChecked="True" Checked="ThemeRadio_Checked"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Backend Server Management -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE968;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="后端服务器"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="管理和切换后端服务器连接"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       Margin="28,0,0,0"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <!-- Current Backend Info -->
                        <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="6"
                                Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="20"
                                        Width="40"
                                        Height="40"
                                        Margin="0,0,16,0">
                                    <FontIcon Glyph="&#xE774;" FontSize="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="当前连接" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                    <TextBlock Text="{x:Bind CurrentBackendUrl, Mode=OneWay}"
                                               FontWeight="Medium"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Backend List -->
                        <ListView x:Name="BackendListView"
                                  ItemsSource="{x:Bind BackendServers, Mode=OneWay}"
                                  SelectionMode="None"
                                  MaxHeight="320">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4,0,4"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="services:BackendServer">
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Name}"
                                                               FontWeight="SemiBold"
                                                               FontSize="14"/>
                                                    <Border Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Visibility="{x:Bind IsCustom, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="自定义" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Url}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Visibility="{x:Bind LastTestResult, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverter}}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                                    <Run Text="测试于"/>
                                                    <Run Text="{x:Bind LastTestedAt, Mode=OneWay, Converter={StaticResource DateTimeToStringConverter}}"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{x:Bind LastTestResult, Mode=OneWay, Converter={StaticResource BoolToTestResultConverter}}"
                                                         Foreground="{x:Bind LastTestResult, Mode=OneWay, Converter={StaticResource BoolToColorConverter}}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Button Click="TestBackendInList_Click"
                                                        Tag="{x:Bind Url}"
                                                        ToolTipService.ToolTip="测试连接">
                                                    <FontIcon Glyph="&#xE703;" FontSize="14"/>
                                                </Button>
                                                <Button Click="DeleteBackend_Click"
                                                        Tag="{x:Bind Url}"
                                                        Visibility="{x:Bind IsCustom, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        ToolTipService.ToolTip="删除">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Add Backend Button -->
                        <Button Click="AddCustomBackendInSettings_Click"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                <TextBlock Text="添加自定义后端"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Image Storage Settings -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE722;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="图片存储"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="配置图片的存储方式（本地服务器或图床）"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       Margin="28,0,0,0"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <!-- Storage Mode -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="存储模式" FontWeight="Medium"/>
                                <TextBlock Text="选择图片的存储方式"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                                <RadioButton x:Name="LocalStorageRadio" Content="本地存储" Tag="local" GroupName="StorageMode" Checked="StorageMode_Checked"/>
                                <RadioButton x:Name="CdnStorageRadio" Content="图床" Tag="cdn" GroupName="StorageMode" Checked="StorageMode_Checked"/>
                            </StackPanel>
                        </Grid>

                        <!-- CDN Config Panel -->
                        <StackPanel x:Name="CdnConfigPanel" Spacing="16" Visibility="Collapsed">
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                            <TextBlock Text="图床配置" FontWeight="Medium" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                            <!-- Upload URL -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="上传 API" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBox x:Name="CdnUploadUrlBox" Grid.Column="1" PlaceholderText="https://api.imgbb.com/1/upload"/>
                            </Grid>

                            <!-- HTTP Method -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="HTTP 方法" FontWeight="Medium" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CdnMethodCombo" Grid.Column="1" SelectedIndex="0" Width="120">
                                    <ComboBoxItem Content="POST"/>
                                    <ComboBoxItem Content="PUT"/>
                                </ComboBox>
                            </Grid>

                            <!-- File Field -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="文件字段名" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBox x:Name="CdnFileFieldBox" Grid.Column="1" PlaceholderText="file" Text="file"/>
                            </Grid>

                            <!-- Headers -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="请求头" FontWeight="Medium"/>
                                <StackPanel x:Name="HeadersPanel" Spacing="4"/>
                                <Button Click="AddHeader_Click" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        <TextBlock Text="添加请求头" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Extra Params -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="附加参数" FontWeight="Medium"/>
                                <StackPanel x:Name="ExtraParamsPanel" Spacing="4"/>
                                <Button Click="AddExtraParam_Click" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                                        <TextBlock Text="添加参数" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                            <TextBlock Text="响应解析" FontWeight="Medium" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                            <!-- Response URL Field -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="URL 路径" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBox x:Name="CdnResponseUrlFieldBox" Grid.Column="1" PlaceholderText="data.url" Text="data.url"/>
                            </Grid>

                            <!-- Response Delete Field -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="删除凭据路径" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBox x:Name="CdnResponseDeleteFieldBox" Grid.Column="1" PlaceholderText="data.delete_url（可选）"/>
                            </Grid>

                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                            <TextBlock Text="删除配置（可选）" FontWeight="Medium" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                            <!-- Delete URL Template -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="删除 API" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBox x:Name="CdnDeleteUrlTemplateBox" Grid.Column="1" PlaceholderText="https://sm.ms/api/v2/delete/{deleteKey}"/>
                            </Grid>

                            <!-- Delete Method -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="删除方法" FontWeight="Medium" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CdnDeleteMethodCombo" Grid.Column="1" SelectedIndex="0" Width="120">
                                    <ComboBoxItem Content="GET"/>
                                    <ComboBoxItem Content="DELETE"/>
                                    <ComboBoxItem Content="POST"/>
                                </ComboBox>
                            </Grid>

                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                            <TextBlock Text="高级" FontWeight="Medium" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                            <!-- Timeout and Retries -->
                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="超时(秒)" FontWeight="Medium" VerticalAlignment="Center"/>
                                <NumberBox x:Name="CdnTimeoutBox" Grid.Column="1" Value="30" Minimum="5" Maximum="120" SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="2" Text="重试次数" FontWeight="Medium" VerticalAlignment="Center"/>
                                <NumberBox x:Name="CdnMaxRetriesBox" Grid.Column="3" Value="2" Minimum="0" Maximum="5" SpinButtonPlacementMode="Compact"/>
                            </Grid>
                        </StackPanel>

                        <!-- Save & Test Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Click="SaveImageStorageConfig_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                    <TextBlock Text="保存配置"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="TestCdnButton" Click="TestCdnConnection_Click" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE703;" FontSize="14"/>
                                    <TextBlock Text="测试连接"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- IP Location API Settings -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE81D;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="IP 属地查询"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="配置 cn.apihz.cn 的 API 凭据，用于评论和留言的 IP 属地显示"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       Margin="28,0,0,0"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <!-- User ID -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="用户 ID" FontWeight="Medium" VerticalAlignment="Center" Width="80"/>
                            <TextBox x:Name="IpApiUserIdBox"
                                     Grid.Column="1"
                                     PlaceholderText="请输入 cn.apihz.cn 的用户 ID"/>
                        </Grid>

                        <!-- User Key -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="用户密钥" FontWeight="Medium" VerticalAlignment="Center" Width="80"/>
                            <PasswordBox x:Name="IpApiUserKeyBox"
                                         Grid.Column="1"
                                         PlaceholderText="请输入 API 密钥"/>
                        </Grid>

                        <!-- Save Button -->
                        <Button Click="SaveIpApiCredentials_Click"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                <TextBlock Text="保存凭据"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Account Actions -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xF22C;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="GitHub Token"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="配置 Personal Access Token 以提升 API 速率限制（60 → 5000 次/小时），Token 仅存储在本地"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="28,0,0,0"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <!-- Token Input -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Token" FontWeight="Medium" VerticalAlignment="Center" Width="80"/>
                            <PasswordBox x:Name="GitHubTokenBox"
                                         Grid.Column="1"
                                         PlaceholderText="ghp_xxxx（Fine-grained PAT，无需任何权限即可读取公开仓库）"/>
                        </Grid>

                        <!-- Save Button -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Click="SaveGitHubToken_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                    <TextBlock Text="保存"/>
                                </StackPanel>
                            </Button>
                            <Button Click="ClearGitHubToken_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    <TextBlock Text="清除"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Account Actions -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8AB;" FontSize="18" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                <TextBlock Text="账户操作"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="退出登录或切换账户"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       Margin="28,0,0,0"/>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <!-- Current User Info -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="当前登录账户" FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind CurrentUsername, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"/>
                                    <TextBlock Text="·"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               FontSize="13"/>
                                    <TextBlock Text="{x:Bind CurrentNickname, Mode=OneWay}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    x:Name="LogoutButton"
                                    Click="LogoutButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xF3B1;" FontSize="14"/>
                                    <TextBlock Text="退出登录"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- About Section -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel Spacing="20">
                        <!-- Section Header -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="关于"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-24,0"/>

                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- App Icon -->
                            <Border Grid.Column="0"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="12"
                                    Width="64"
                                    Height="64">
                                <FontIcon Glyph="&#xE70F;" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- App Info -->
                            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="星光小栈博客管理系统"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <TextBlock x:Name="VersionText" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Check Update -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="检查更新" FontWeight="Medium"/>
                                <TextBlock x:Name="UpdateStatusText"
                                           Text="点击右侧按钮检查新版本"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>

                            <Button x:Name="CheckUpdateButton"
                                    Grid.Column="1"
                                    Click="CheckUpdateButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE895;" FontSize="14"/>
                                    <TextBlock Text="检查更新"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Changelog Expander -->
                        <Expander x:Name="ChangelogExpander"
                                  Header="更新日志"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Expanding="ChangelogExpander_Expanding">
                            <StackPanel Spacing="8">
                                <ProgressRing x:Name="ChangelogLoadingRing"
                                              IsActive="False"
                                              Width="24" Height="24"
                                              Visibility="Collapsed"
                                              HorizontalAlignment="Center"/>
                                <ListView x:Name="ChangelogListView"
                                          SelectionMode="None"
                                          MaxHeight="400">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,4"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>
                                <TextBlock x:Name="ChangelogEmptyText"
                                           Text="暂无更新日志"
                                           Visibility="Collapsed"
                                           HorizontalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           FontSize="13"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
