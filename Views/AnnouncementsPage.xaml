<Page
    x:Class="Blog_Manager.Views.AnnouncementsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <!-- Content Area (Animated) -->
        <Grid>
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </Grid.Transitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Error Display -->
            <InfoBar Grid.Row="0"
                     Severity="Error"
                     Title="加载失败"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Margin="0,0,0,16"/>

            <!-- Announcements List -->
            <ScrollViewer Grid.Row="1">
            <ListView ItemsSource="{x:Bind ViewModel.Announcements, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Announcement">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="16"
                               Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Title and Status -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="{x:Bind Title}"
                                              FontWeight="SemiBold"
                                              FontSize="16"/>

                                    <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                           CornerRadius="4"
                                           Padding="8,4"
                                           HorizontalAlignment="Right"
                                           Visibility="{x:Bind IsEnabled}">
                                        <TextBlock Text="已启用"
                                                  Foreground="White"
                                                  FontSize="12"/>
                                    </Border>
                                </Grid>

                                <!-- Content -->
                                <TextBlock Grid.Row="1"
                                          Text="{x:Bind Content}"
                                          TextWrapping="Wrap"
                                          MaxLines="3"
                                          TextTrimming="CharacterEllipsis"
                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                          Margin="0,0,0,12"/>

                                <!-- Time Info -->
                                <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,12">
                                    <TextBlock Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontSize="12">
                                        <Run Text="创建时间:"/>
                                        <Run Text="{x:Bind CreatedAt}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontSize="12">
                                        <Run Text="开始时间:"/>
                                        <Run Text="{x:Bind StartTime}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontSize="12">
                                        <Run Text="结束时间:"/>
                                        <Run Text="{x:Bind EndTime}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                    <Button Tag="{x:Bind Id}"
                                           Click="EditButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Edit"/>
                                            <TextBlock Text="编辑" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Tag="{x:Bind Id}"
                                           Click="DeleteButton_Click">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonForeground" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#B71C1C"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Delete"/>
                                            <TextBlock Text="删除" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
              Opacity="0.8">
            <ProgressRing IsActive="True"
                         Width="60"
                         Height="60"/>
        </Grid>
    </Grid>
</Page>
