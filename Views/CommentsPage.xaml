<Page
    x:Class="Blog_Manager.Views.CommentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    xmlns:converters="using:Blog_Manager.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter and Sort Toolbar (Fixed, No Animation) -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Filter by Article -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,16,0">
                    <TextBlock Text="按文章筛选:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ArticleFilterComboBox"
                             PlaceholderText="全部文章"
                             MinWidth="150"
                             SelectionChanged="ArticleFilterComboBox_SelectionChanged"/>
                </StackPanel>

                <!-- Filter by Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,16,0">
                    <TextBlock Text="按审核情况筛选:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="StatusFilterComboBox"
                             PlaceholderText="全部状态"
                             MinWidth="120"
                             SelectionChanged="StatusFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="全部" Tag="0"/>
                        <ComboBoxItem Content="已审核" Tag="1"/>
                        <ComboBoxItem Content="待审核" Tag="2"/>
                    </ComboBox>
                </StackPanel>

                <!-- Sort by Time -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="按时间排序:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="TimeSortComboBox"
                             SelectedIndex="0"
                             MinWidth="100"
                             SelectionChanged="TimeSortComboBox_SelectionChanged">
                        <ComboBoxItem Content="最新优先" Tag="desc"/>
                        <ComboBoxItem Content="最早优先" Tag="asc"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Comments List (Animated) -->
        <ScrollViewer Grid.Row="1">
            <ScrollViewer.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </ScrollViewer.Transitions>
            <ListView ItemsSource="{x:Bind ViewModel.Comments, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Comment">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="16"
                               Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 1: Author and Article Info with Status -->
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Nickname}"
                                                  FontWeight="SemiBold"
                                                  FontSize="14"/>
                                        <TextBlock Text="评论于"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  FontSize="12"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8A5;"
                                                     FontSize="12"
                                                     Foreground="{ThemeResource SystemAccentColor}"/>
                                            <TextBlock Text="{x:Bind SafeArticleTitle}"
                                                      Foreground="{ThemeResource SystemAccentColor}"
                                                      FontSize="12"
                                                      FontWeight="SemiBold"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsApproved, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="已审核"
                                                      Foreground="White"
                                                      FontSize="12"/>
                                        </Border>
                                        <Border Background="{ThemeResource SystemFillColorCautionBrush}"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsApproved, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                            <TextBlock Text="待审核"
                                                      Foreground="White"
                                                      FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2: Time, IP Location, Device Info -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE823;"
                                                 FontSize="12"
                                                 Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{x:Bind CreatedAtText}"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE81D;"
                                                 FontSize="12"
                                                 Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{x:Bind IpLocation, Mode=OneWay}"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE7F8;"
                                                 FontSize="12"
                                                 Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{x:Bind DeviceInfo}"
                                                  Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                  FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Row 3: Reply To (if exists) -->
                                <StackPanel Grid.Row="2"
                                           Orientation="Horizontal"
                                           Spacing="4"
                                           Margin="0,0,0,8"
                                           Visibility="{x:Bind ReplyToNickname, Converter={StaticResource StringToVisibilityConverter}}">
                                    <TextBlock Text="回复给:"
                                              Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontSize="12"/>
                                    <TextBlock Text="{x:Bind ReplyToNickname}"
                                              Foreground="{ThemeResource SystemAccentColor}"
                                              FontSize="12"
                                              FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- Row 4: Content -->
                                <TextBlock Grid.Row="3"
                                          Text="{x:Bind Content}"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,12"/>

                                <!-- Row 5: Actions -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                                    <Button Tag="{x:Bind Id}"
                                           Click="ApproveButton_Click"
                                           Visibility="{x:Bind IsApproved, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE73E;"/>
                                            <TextBlock Text="通过" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Tag="{x:Bind Id}"
                                           Click="RejectButton_Click"
                                           Visibility="{x:Bind IsApproved, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE711;"/>
                                            <TextBlock Text="标记待审核" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Tag="{x:Bind Id}"
                                           Click="DeleteButton_Click">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonForeground" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#B71C1C"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Delete"/>
                                            <TextBlock Text="删除" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Page>
