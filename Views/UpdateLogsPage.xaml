<Page
    x:Class="Blog_Manager.Views.UpdateLogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Blog_Manager.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <!-- Content Area (Animated) -->
        <Grid>
            <Grid.Transitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50"/>
                </TransitionCollection>
            </Grid.Transitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Error Display -->
            <InfoBar Grid.Row="0"
                     Severity="Error"
                     Title="加载失败"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Margin="0,0,0,16"/>

            <!-- Update Logs List -->
            <ScrollViewer Grid.Row="1">
            <ListView ItemsSource="{x:Bind ViewModel.UpdateLogs, Mode=OneWay}"
                     SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UpdateLog">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                               BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                               BorderThickness="1"
                               CornerRadius="8"
                               Padding="16"
                               Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Version, Title and Status Badges -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center">
                                            <Run Text="版本"/>
                                            <Run Text="{x:Bind Version}"/>
                                        </TextBlock>

                                        <!-- Pending Badge -->
                                        <Border Background="#94a3b8"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsPendingVisibility}">
                                            <TextBlock Text="待发布"
                                                      Foreground="White"
                                                      FontSize="12"/>
                                        </Border>

                                        <!-- Major Update Badge -->
                                        <Border Background="{ThemeResource SystemFillColorCriticalBrush}"
                                               CornerRadius="4"
                                               Padding="8,4"
                                               Visibility="{x:Bind IsMajorUpdateVisibility}">
                                            <TextBlock Text="重大更新"
                                                      Foreground="White"
                                                      FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Title (if exists) -->
                                <TextBlock Grid.Row="1"
                                          Text="{x:Bind Title}"
                                          FontWeight="Medium"
                                          FontSize="14"
                                          Margin="0,0,0,8"
                                          Visibility="{x:Bind Title, Converter={StaticResource StringToVisibilityConverter}}"/>

                                <!-- Content -->
                                <TextBlock Grid.Row="2"
                                          Text="{x:Bind Content}"
                                          TextWrapping="Wrap"
                                          MaxLines="5"
                                          TextTrimming="CharacterEllipsis"
                                          Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                          Margin="0,0,0,12"/>

                                <!-- Release Date and Created Time -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="16" Margin="0,0,0,12">
                                    <TextBlock Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontSize="12">
                                        <Run Text="发布日期:"/>
                                        <Run Text="{x:Bind DisplayReleaseDate}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                              FontSize="12">
                                        <Run Text="创建时间:"/>
                                        <Run Text="{x:Bind DisplayCreatedAt}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                                    <Button Tag="{x:Bind Id}"
                                           Click="EditButton_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Edit"/>
                                            <TextBlock Text="编辑" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Tag="{x:Bind Id}"
                                           Click="DeleteButton_Click">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonForeground" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D32F2F"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#B71C1C"/>
                                        </Button.Resources>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <SymbolIcon Symbol="Delete"/>
                                            <TextBlock Text="删除" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
              Opacity="0.8">
            <ProgressRing IsActive="True"
                         Width="60"
                         Height="60"/>
        </Grid>
    </Grid>
</Page>
