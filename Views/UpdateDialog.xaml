<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Blog_Manager.Views.UpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="发现新版本"
    PrimaryButtonText="立即更新"
    SecondaryButtonText="跳过此版本"
    CloseButtonText="稍后提醒"
    DefaultButton="Primary"
    PrimaryButtonClick="PrimaryButton_Click"
    SecondaryButtonClick="SecondaryButton_Click">

    <StackPanel Spacing="16" Width="480">
        <!-- Version Info -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="当前版本"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="CurrentVersionText"
                           FontSize="16"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="最新版本"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="LatestVersionText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Changelog -->
        <StackPanel Spacing="8">
            <TextBlock Text="更新内容"
                       Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <ScrollViewer MaxHeight="250"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          CornerRadius="8"
                          Padding="16"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock x:Name="ChangelogText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           IsTextSelectionEnabled="True"/>
            </ScrollViewer>
        </StackPanel>

        <!-- Download Progress -->
        <StackPanel x:Name="DownloadPanel" Visibility="Collapsed" Spacing="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DownloadStatusText"
                           Text="正在下载..."
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="DownloadPercentText"
                           Grid.Column="1"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </Grid>
            <ProgressBar x:Name="DownloadProgress"
                         Minimum="0"
                         Maximum="100"/>
        </StackPanel>

        <!-- Error / Fallback -->
        <InfoBar x:Name="ErrorInfoBar"
                 Severity="Error"
                 IsOpen="False"
                 IsClosable="True"
                 Title="下载失败"/>

        <HyperlinkButton x:Name="OpenInBrowserBtn"
                         Visibility="Collapsed"
                         Content="在浏览器中打开下载页"
                         Click="OpenInBrowser_Click"/>

        <!-- Download Size -->
        <TextBlock x:Name="DownloadSizeText"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
    </StackPanel>
</ContentDialog>
